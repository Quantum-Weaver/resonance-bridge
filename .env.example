# PROMETHEUS — environment template
# Copy to `.env` and fill in. The real .env is gitignored and NEVER committed.
# RULE: keys go straight from the provider dashboard into your .env by your
# own hands. Never paste a real key into any chat — with any AI, ever.
# If one ever leaks anywhere, rotate it at the dashboard immediately.

# ── PHASE 1 (local Grammar) — NO KEYS REQUIRED ─────────────────────
# knowledge.db path only; not secret, but configurable:
KNOWLEDGE_DB_PATH=C:/_superposition/resonance-knowledge/knowledge.db

# ── PHASE 2 (Supabase: Superposition + resonance-knowledge cloud) ──
# From: Supabase dashboard → Project Settings → API
# Use the ANON key (read-only ward); avoid the service_role key unless a
# consent-gated write tool explicitly requires it.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── PHASE 3 (service lines) ────────────────────────────────────────
# Leonardo AI (pro): app.leonardo.ai → API Access
LEONARDO_API_KEY=

# Kimi / Moonshot (pro): platform.moonshot.ai → API Keys
# First test per the Weaver's directive: bridge the Library's gaps.
MOONSHOT_API_KEY=

# DaVinci (trial ends ~2026-07-09 — time-boxed spike only)
DAVINCI_API_KEY=

# ── PHASE 4 (Aethelred's local line) ───────────────────────────────
# Local only when the Alienware home stands; no cloud key. Placeholder:
AETHELRED_LOCAL_URL=http://localhost:11434
